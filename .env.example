# ═══════════════════════════════════════════════════════════════
# CONCLAVE AEGIS DISCORD CORE v9.0 — .env.example
# Music Runtime + Full Bot
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
BOT_PORT=3001

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=1438103556610723922

# Roles
ROLE_OWNER_ID=
ROLE_ADMIN_ID=
ROLE_HELPER_ID=

# Platform API
API_URL=https://api.theconclavedominion.com
ADMIN_TOKEN=

# Supabase
SUPABASE_URL=https://idbexlahxuelfrcbhfqs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# AEGIS channel
AEGIS_CHANNEL_ID=

# Beacon Sentinel
BEACON_CLIENT_ID=eb9ecdff-4048-4a83-8f40-f2e16d2e9a81
BEACON_CLIENT_SECRET=
BEACON_ACCESS_TOKEN=
BEACON_REFRESH_TOKEN=
BEACON_TOKEN_EXPIRES=
BEACON_GROUP_ID=

# Nitrado
NITRADO_API_KEY=

# Live Monitor
MONITOR_STATUS_CHANNEL_ID=
MONITOR_ACTIVITY_CHANNEL_ID=
MONITOR_MESSAGE_ID=

# ─── MUSIC RUNTIME ────────────────────────────────────────────
# Set to false to disable music (saves memory on free tier)
MUSIC_RUNTIME_ENABLED=true

# play-dl auth — paste your Spotify/SoundCloud creds for enhanced search
# Get at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# SoundCloud (optional — improves SC search quality)
SOUNDCLOUD_CLIENT_ID=

# YouTube cookie (paste from browser DevTools → Application → Cookies → .youtube.com)
# Improves reliability, avoids "Sign in to confirm" blocks
YOUTUBE_COOKIE=

# Max permanent mood rooms (default 5)
MUSIC_MAX_ROOMS=5
# Auto-reconnect delay ms (default 5000)
ROOM_RECONNECT_LIMIT=5000
# Room health pulse interval ms (default 30000)
ROOM_PULSE_INTERVAL=30000
# Enable mood room fallback when queue empties
MUSIC_FALLBACK_ENABLED=true

# Optional legacy alias used by upgraded knowledge_db.js
SUPABASE_SERVICE_KEY=

# Music reconnect delay ms
ROOM_RECONNECT_DELAY=5000
# Launchpad embed refresh ms
LAUNCHPAD_EDIT_INTERVAL=12000
