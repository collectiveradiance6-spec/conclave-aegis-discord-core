# ═══════════════════════════════════════════════════════════════════════
# CONCLAVE AEGIS BOT — v10.0 SOVEREIGN EDITION
# .env.example — Copy to .env and fill in values. NEVER commit .env.
# ═══════════════════════════════════════════════════════════════════════

NODE_ENV=production
BOT_PORT=3001

# ─── Discord ──────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=1438103556610723922

# ─── Roles (right-click role in Discord → Copy ID) ───────────────────
ROLE_OWNER_ID=
ROLE_ADMIN_ID=
ROLE_HELPER_ID=

# ─── Platform API ─────────────────────────────────────────────────────
API_URL=https://api.theconclavedominion.com
ADMIN_TOKEN=

# ─── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=https://idbexlahxuelfrcbhfqs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Legacy alias used by older modules:
SUPABASE_SERVICE_KEY=

# ─── Anthropic (AEGIS AI) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Model routing is automatic:
#   Fast: claude-haiku-4-5-20251001 (simple queries, ~$0.001/call)
#   Smart: claude-sonnet-4-6 (complex + web search, ~$0.01/call)

# ─── AEGIS Auto-reply Channel ─────────────────────────────────────────
# The Discord channel ID where AEGIS auto-replies to messages
AEGIS_CHANNEL_ID=

# ─── Shop ────────────────────────────────────────────────────────────
# Channel ID to post order embeds from /order command
ORDERS_CHANNEL_ID=
# Discord webhook URL for shop order notifications
DISCORD_WEBHOOK_URL=
SHOP_WEBHOOK_URL=

# ─── Music Runtime ────────────────────────────────────────────────────
MUSIC_RUNTIME_ENABLED=true
MUSIC_FALLBACK_ENABLED=true

# Music API URL — the bot syncs session state here every 15s
MUSIC_API_URL=https://api.theconclavedominion.com

# DJ Role ID — leave blank for anyone to control music
MUSIC_DJ_ROLE_ID=

# Timing
ROOM_PULSE_INTERVAL=30000
ROOM_RECONNECT_DELAY=5000
LAUNCHPAD_EDIT_INTERVAL=12000

# ─── Spotify (improves Spotify link resolution) ───────────────────────
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ─── SoundCloud (optional — improves SC search) ───────────────────────
SOUNDCLOUD_CLIENT_ID=

# ─── YouTube (optional — avoids "sign in to confirm" errors) ─────────
# Get from browser DevTools → Application → Cookies → .youtube.com → VISITOR_INFO1_LIVE
YOUTUBE_COOKIE=

# ─── Beacon Sentinel ──────────────────────────────────────────────────
BEACON_CLIENT_ID=eb9ecdff-4048-4a83-8f40-f2e16d2e9a81
BEACON_CLIENT_SECRET=
BEACON_ACCESS_TOKEN=
BEACON_REFRESH_TOKEN=
BEACON_TOKEN_EXPIRES=
BEACON_GROUP_ID=

# ─── Nitrado (live server stats) ──────────────────────────────────────
NITRADO_API_KEY=

# ─── Live Monitor ─────────────────────────────────────────────────────
# After running /setup-monitoring, copy the channel/message IDs here:
MONITOR_STATUS_CHANNEL_ID=
MONITOR_ACTIVITY_CHANNEL_ID=
MONITOR_MESSAGE_ID=
