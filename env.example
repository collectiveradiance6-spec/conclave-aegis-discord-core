# ═══════════════════════════════════════════════════════════════════════
# CONCLAVE AEGIS v10.0 SOVEREIGN EDITION — .env.example
# ═══════════════════════════════════════════════════════════════════════

NODE_ENV=production
BOT_PORT=3001

# ─── Discord ──────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=1438103556610723922

# ─── Roles ────────────────────────────────────────────────────────────
ROLE_OWNER_ID=
ROLE_ADMIN_ID=
ROLE_HELPER_ID=

# ─── Platform API ─────────────────────────────────────────────────────
API_URL=https://api.theconclavedominion.com
ADMIN_TOKEN=

# ─── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=https://idbexlahxuelfrcbhfqs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (AEGIS AI) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Model tiers (do not change — auto-selected by query complexity)
# Fast: claude-haiku-4-5-20251001 (simple queries, ~$0.001/call)
# Smart: claude-sonnet-4-6 (complex + web search, ~$0.01/call)

# ─── AEGIS Auto-reply Channel ─────────────────────────────────────────
AEGIS_CHANNEL_ID=

# ─── Beacon Sentinel ──────────────────────────────────────────────────
BEACON_CLIENT_ID=eb9ecdff-4048-4a83-8f40-f2e16d2e9a81
BEACON_CLIENT_SECRET=
BEACON_ACCESS_TOKEN=
BEACON_REFRESH_TOKEN=
BEACON_TOKEN_EXPIRES=
BEACON_GROUP_ID=

# ─── Nitrado (live server stats) ──────────────────────────────────────
NITRADO_API_KEY=

# ─── Live Monitor ─────────────────────────────────────────────────────
MONITOR_STATUS_CHANNEL_ID=
MONITOR_ACTIVITY_CHANNEL_ID=
MONITOR_MESSAGE_ID=

# ─── Music Runtime ────────────────────────────────────────────────────
MUSIC_RUNTIME_ENABLED=true
MUSIC_FALLBACK_ENABLED=true
MUSIC_DJ_ROLE_ID=
# Set to the role ID that controls music. Leave blank = anyone can control.

ROOM_PULSE_INTERVAL=30000
ROOM_RECONNECT_DELAY=5000

# Spotify (optional — improves Spotify track resolution quality)
# Get at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# SoundCloud (optional)
SOUNDCLOUD_CLIENT_ID=

# YouTube cookie (optional — avoids "sign in to confirm" blocks on some tracks)
# Get from browser DevTools → Application → Cookies → .youtube.com → copy value
YOUTUBE_COOKIE=
