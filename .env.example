# CONCLAVE AEGIS DISCORD CORE — .env.example
# Repo: conclave-aegis-discord-core (NEW GitHub repo)
# Render type: Background Worker
# NEVER commit .env
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
BOT_PORT=3001

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=1438103556610723922

# Discord Role IDs
ROLE_OWNER_ID=
ROLE_ADMIN_ID=
ROLE_HELPER_ID=

# Platform API (server.js on Render)
API_URL=https://api.theconclavedominion.com
ADMIN_TOKEN=

# Supabase — SAME project as platform
# Use SERVICE ROLE KEY (bot runs server-side only)
SUPABASE_URL=https://idbexlahxuelfrcbhfqs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (AEGIS AI in Discord)
ANTHROPIC_API_KEY=

# AEGIS auto-reply channel
AEGIS_CHANNEL_ID=

# Beacon Sentinel
BEACON_CLIENT_ID=eb9ecdff-4048-4a83-8f40-f2e16d2e9a81
BEACON_CLIENT_SECRET=
BEACON_ACCESS_TOKEN=
BEACON_REFRESH_TOKEN=
BEACON_TOKEN_EXPIRES=
BEACON_GROUP_ID=

# Nitrado (direct server status — optional, falls back to BattleMetrics)
NITRADO_API_KEY=

# Live Monitor (set after /setup-monitoring runs in Discord)
MONITOR_STATUS_CHANNEL_ID=
MONITOR_ACTIVITY_CHANNEL_ID=
MONITOR_MESSAGE_ID=
